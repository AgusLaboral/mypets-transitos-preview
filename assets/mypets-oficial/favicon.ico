        { "@type": "Question", "name": "¿Quién ve mis reportes?", "acceptedAnswer": { "@type": "Answer", "text": "Los reportes son visibles para todos los usuarios en Argentina, con notificaciones a usuarios cercanos." } },
        { "@type": "Question", "name": "¿Puedo reportar mascotas ajenas?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, podés cargar reportes de mascotas encontradas o avistadas para ayudar a la comunidad." } }
